{
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "node16",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["vite.config.ts", "postcss.config.js"]
}
